# Elasticsearch Cloud Serverless
ES_URL=https://your-project.es.region.cloud.es.io
ES_API_KEY=your-encoded-api-key

# AWS Bedrock — pick ONE auth style:

# A) Bedrock API key (console “API keys”) — recommended for quick dev
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# B) IAM programmatic access (omit AWS_BEARER_TOKEN_BEDROCK). Short-lived keys need token.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
